# Server
PORT=3000
NODE_ENV=development

# Database — Railway will inject this automatically when you link a Postgres service
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/caliapp"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace-me-with-random-32-bytes
JWT_REFRESH_SECRET=replace-me-with-different-random-32-bytes
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# CORS — comma-separated list of allowed origins. Local default works for dev.
# In Railway, set this to your frontend service URL (e.g., https://caliapp-client.up.railway.app)
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173